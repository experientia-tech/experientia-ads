# Copy to .env and fill in real values. Do NOT commit the real .env.

# --- Database (PostgreSQL: AWS RDS / Supabase) ---
# Do NOT append ?sslmode=require for RDS — TLS is configured in lib/prisma.ts
# (rejectUnauthorized:false). For a local Postgres, use a localhost host and TLS
# is skipped automatically.
DATABASE_URL="postgresql://user:password@host:5432/postgres"

# --- Auth ---
JWT_SECRET="change-me-to-a-long-random-string"
# Static login OTP used until a real SMS/OTP provider is integrated.
# Login fails closed if this is unset.
AUTH_OTP="000000"

# --- AWS S3 (document uploads / presigned URLs) ---
REGION_AWS="ap-south-1"
ACCESS_KEY_AWS_ID=""
SECRET_KEY_AWS=""
S3_BUCKET_NAME=""

# --- Maps ---
NEXT_PUBLIC_MAPBOX_TOKEN=""

# --- Geocoding (optional; providers are skipped if unset) ---
NEXT_PUBLIC_OPENCAGE_API_KEY=""
NEXT_PUBLIC_LOCATIONIQ_API_KEY=""
